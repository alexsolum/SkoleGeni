{
  "name": "skolegeni",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "verify:phase1": "npm run build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:phase2": "npm run test -- src/pages/__tests__/configuration-load.test.tsx src/pages/__tests__/configuration-save.test.tsx src/pages/__tests__/pupil-import-validation.test.tsx src/pages/__tests__/pupil-autosave.test.tsx src/pages/__tests__/workflow-reload.test.tsx && npm run test:e2e -- tests/phase2-workflow.spec.ts && npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@supabase/supabase-js": "2.99.2",
    "clsx": "2.1.1",
    "lodash.debounce": "4.0.8",
    "papaparse": "5.5.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "2.6.0",
    "react-router-dom": "7.13.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "3.5.0",
    "zundo": "^2.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "29.0.1",
    "postcss": "8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "8.0.0",
    "vitest": "4.1.0"
  }
}
